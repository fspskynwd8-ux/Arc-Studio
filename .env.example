# ══════════════════════════════════════════════════════════════
# Arc Studio — IONOS FTP Zugangsdaten (Beispiel)
# WICHTIG: Diese Datei kopieren als ".env" und ausfüllen
# NIEMALS ".env" committen — nur ".env.example"!
# ══════════════════════════════════════════════════════════════

# FTP-Zugangsdaten aus IONOS Control Panel (Hosting → FTP)
IONOS_FTP_HOST=ftp.deine-domain.de
IONOS_FTP_USER=dein-ftp-benutzer
IONOS_FTP_PASS=dein-ftp-passwort
IONOS_FTP_DIR=/
